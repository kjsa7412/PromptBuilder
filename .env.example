# ===== PromptBuilder / PromptClip =====
# Copy this file to .env and fill in the values

# ----- Database (Local Postgres) -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=promptbuilder
DB_USER=promptbuilder
DB_PASSWORD=changeme
DATABASE_URL=postgresql://promptbuilder:changeme@localhost:5432/promptbuilder

# ----- Supabase (Auth) -----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# ----- Front (Next.js) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_CHAT_UI_URL=https://chat.openai.com

# ----- Back (Spring Boot) -----
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/promptbuilder
SPRING_DATASOURCE_USERNAME=promptbuilder
SPRING_DATASOURCE_PASSWORD=changeme
JWT_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
JWT_ISSUER=https://your-project.supabase.co/auth/v1
JWT_AUDIENCE=authenticated

# ----- Guardrails -----
# Set ALLOW_PROD=1 ONLY after PR approval to enable prod deploy commands
ALLOW_PROD=0

# ----- Rate Limits -----
GENERATE_DAILY_LIMIT_PER_USER=50
GENERATE_HOURLY_LIMIT_ANONYMOUS=20
