{
  "projectName": "PromptBuilder (PromptClip)",
  "version": "1.1.0",
  "agents": {
    "directory": ".claude/agents",
    "activeAgents": [
      "delivery_orchestrator",
      "foundation_builder",
      "product_policy",
      "ux_ui",
      "solution_architect_api_contract",
      "front_implementer",
      "back_implementer",
      "db_schema_migration_author",
      "qa_gatekeeper",
      "release_deployment"
    ]
  },
  "skills": {
    "directory": ".claude/skills"
  },
  "hooks": {
    "directory": ".claude/hooks",
    "guardrails": ".claude/hooks/preflight.sh"
  },
  "conventions": {
    "monoRepo": "A",
    "backStyle": "MyBatis-Map-only",
    "frontStyle": "NextJS-AppRouter",
    "dbPolicy": "no-FK-no-RLS",
    "authSource": "Supabase-JWT"
  },
  "guardrails": {
    "blockedWithoutAllowProd": [
      "vercel --prod",
      "vercel deploy --prod",
      "railway up",
      "railway deploy",
      "supabase db push",
      "supabase link",
      "terraform apply"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(chmod +x mvnw)",
      "Bash(./mvnw test -q)",
      "Bash(./mvnw test)",
      "Bash(bash scripts/gate.sh)",
      "Bash(docker-compose up -d)",
      "Bash(docker compose version)",
      "Bash(docker --version)",
      "Bash(where docker)",
      "Bash(powershell.exe -Command \"Get-Command docker -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source\")"
    ]
  }
}
